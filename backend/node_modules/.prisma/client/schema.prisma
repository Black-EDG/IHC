generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum EstadoAsistencia {
  PRESENTE
  AUSENTE
  TARDANZA
  JUSTIFICADO
}

enum EstadoJustificacion {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum EstadoMatricula {
  ACTIVO
  INACTIVO
  GRADUADO
  RETIRADO
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
  NO_ESPECIFICA
}

enum Parentesco {
  PADRE
  MADRE
  TUTOR_LEGAL
  OTRO
}

// ==========================================
// USUARIOS, ROLES Y PERMISOS
// ==========================================

model Rol {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique @db.VarChar(50)
  descripcion String?      @db.Text
  usuarios    Usuario[]
  permisos    RolPermiso[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model Permiso {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique @db.VarChar(100)
  descripcion String?      @db.Text
  modulo      String       @db.VarChar(50)
  roles       RolPermiso[]
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("permisos")
}

model RolPermiso {
  rolId     Int     @map("rol_id")
  permisoId Int     @map("permiso_id")
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("rol_permiso")
}

model Usuario {
  id                  Int       @id @default(autoincrement())
  email               String    @unique @db.VarChar(255)
  passwordHash        String    @map("password_hash")
  nombre              String    @db.VarChar(100)
  apellido            String    @db.VarChar(100)
  telefono            String?   @db.VarChar(20)
  direccion           String?   @db.Text
  fotoUrl             String?   @map("foto_url")
  rolId               Int       @map("rol_id")
  rol                 Rol       @relation(fields: [rolId], references: [id])
  activo              Boolean   @default(true)
  ultimoAcceso        DateTime? @map("ultimo_acceso")
  intentosFallidos    Int       @default(0) @map("intentos_fallidos")
  bloqueadoHasta      DateTime? @map("bloqueado_hasta")
  refreshTokenHash    String?   @map("refresh_token_hash") @db.Text
  resetPasswordToken  String?   @map("reset_password_token") @db.VarChar(255)
  resetPasswordExpira DateTime? @map("reset_password_expira")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  estudiante               Estudiante?
  docente                  Docente?
  apoderado                Apoderado?
  notificaciones           Notificacion[]
  sesiones                 Sesion[]
  auditorias               Auditoria[]
  asistenciasRegistradas   Asistencia[]    @relation("AsistenciaRegistradaPor")
  justificacionesRevisadas Justificacion[] @relation("JustificacionRevisadaPor")

  @@map("usuarios")
}

// ==========================================
// PERSONAS: ESTUDIANTE, DOCENTE, APODERADO
// ==========================================

model Estudiante {
  id               Int       @id @default(autoincrement())
  usuarioId        Int       @unique @map("usuario_id")
  usuario          Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  codigoEstudiante String    @unique @map("codigo_estudiante") @db.VarChar(20)
  fechaNacimiento  DateTime? @map("fecha_nacimiento") @db.Date
  genero           Genero?
  alergias         String?   @db.Text
  observaciones    String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  matriculas      Matricula[]
  asistencias     Asistencia[]
  justificaciones Justificacion[]
  apoderados      EstudianteApoderado[]

  @@map("estudiantes")
}

model Docente {
  id              Int      @id @default(autoincrement())
  usuarioId       Int      @unique @map("usuario_id")
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  codigoDocente   String   @unique @map("codigo_docente") @db.VarChar(20)
  especialidad    String?  @db.VarChar(100)
  tituloAcademico String?  @map("titulo_academico") @db.VarChar(200)
  experiencia     Int?     @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  horarios        Horario[]
  cursosAsignados DocenteCurso[]

  @@map("docentes")
}

model Apoderado {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @unique @map("usuario_id")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  ocupacion String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  estudiantes EstudianteApoderado[]

  @@map("apoderados")
}

model EstudianteApoderado {
  estudianteId        Int        @map("estudiante_id")
  apoderadoId         Int        @map("apoderado_id")
  parentesco          Parentesco
  esContactoPrincipal Boolean    @default(false) @map("es_contacto_principal")

  estudiante Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  apoderado  Apoderado  @relation(fields: [apoderadoId], references: [id], onDelete: Cascade)

  @@id([estudianteId, apoderadoId])
  @@map("estudiante_apoderado")
}

// ==========================================
// ESTRUCTURA ACADÉMICA (SECUNDARIA)
// ==========================================

model Grado {
  id         Int          @id @default(autoincrement())
  nombre     String       @unique @db.VarChar(50)
  orden      Int          @unique
  secciones  Seccion[]
  cursos     GradoCurso[]
  horarios   Horario[] // ← RELACIÓN INVERSA AGREGADA
  matriculas Matricula[] // ← RELACIÓN INVERSA AGREGADA
  createdAt  DateTime     @default(now()) @map("created_at")

  @@map("grados")
}

model Seccion {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(10)
  gradoId   Int      @map("grado_id")
  grado     Grado    @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  capacidad Int      @default(30)
  createdAt DateTime @default(now()) @map("created_at")

  horarios   Horario[]
  matriculas Matricula[]

  @@unique([nombre, gradoId])
  @@map("secciones")
}

model Curso {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique @db.VarChar(100)
  descripcion String?  @db.Text
  creditos    Int      @default(1)
  color       String?  @db.VarChar(7)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  grados   GradoCurso[]
  docentes DocenteCurso[]
  horarios Horario[]

  @@map("cursos")
}

model GradoCurso {
  id      Int   @id @default(autoincrement())
  gradoId Int   @map("grado_id")
  cursoId Int   @map("curso_id")
  grado   Grado @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  curso   Curso @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@unique([gradoId, cursoId])
  @@map("grado_curso")
}

model DocenteCurso {
  id        Int     @id @default(autoincrement())
  docenteId Int     @map("docente_id")
  cursoId   Int     @map("curso_id")
  docente   Docente @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  curso     Curso   @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@unique([docenteId, cursoId])
  @@map("docente_curso")
}

model Aula {
  id        Int      @id @default(autoincrement())
  codigo    String   @unique @db.VarChar(20)
  nombre    String   @db.VarChar(100)
  capacidad Int
  ubicacion String?  @db.VarChar(200)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  horarios Horario[]

  @@map("aulas")
}

model Periodo {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(100)
  fechaInicio DateTime @map("fecha_inicio") @db.Date
  fechaFin    DateTime @map("fecha_fin") @db.Date
  activo      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  matriculas Matricula[]
  horarios   Horario[]

  @@map("periodos")
}

model Horario {
  id         Int      @id @default(autoincrement())
  cursoId    Int      @map("curso_id")
  docenteId  Int      @map("docente_id")
  gradoId    Int      @map("grado_id")
  seccionId  Int      @map("seccion_id")
  aulaId     Int      @map("aula_id")
  periodoId  Int      @map("periodo_id")
  diaSemana  Int      @map("dia_semana")
  horaInicio String   @map("hora_inicio") @db.VarChar(5)
  horaFin    String   @map("hora_fin") @db.VarChar(5)
  createdAt  DateTime @default(now()) @map("created_at")

  curso       Curso        @relation(fields: [cursoId], references: [id])
  docente     Docente      @relation(fields: [docenteId], references: [id])
  grado       Grado        @relation(fields: [gradoId], references: [id])
  seccion     Seccion      @relation(fields: [seccionId], references: [id])
  aula        Aula         @relation(fields: [aulaId], references: [id])
  periodo     Periodo      @relation(fields: [periodoId], references: [id])
  asistencias Asistencia[]

  @@unique([aulaId, diaSemana, horaInicio], name: "uq_horario_aula")
  @@unique([docenteId, diaSemana, horaInicio], name: "uq_horario_docente")
  @@unique([seccionId, diaSemana, horaInicio], name: "uq_horario_seccion")
  @@index([seccionId, periodoId])
  @@map("horarios")
}

// ==========================================
// MATRÍCULA Y ASISTENCIA
// ==========================================

model Matricula {
  id             Int             @id @default(autoincrement())
  estudianteId   Int             @map("estudiante_id")
  gradoId        Int             @map("grado_id")
  seccionId      Int             @map("seccion_id")
  periodoId      Int             @map("periodo_id")
  fechaMatricula DateTime        @default(now()) @map("fecha_matricula") @db.Date
  estado         EstadoMatricula @default(ACTIVO)
  createdAt      DateTime        @default(now()) @map("created_at")

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])
  grado      Grado      @relation(fields: [gradoId], references: [id])
  seccion    Seccion    @relation(fields: [seccionId], references: [id])
  periodo    Periodo    @relation(fields: [periodoId], references: [id])

  @@unique([estudianteId, periodoId])
  @@index([seccionId, periodoId])
  @@map("matriculas")
}

model Asistencia {
  id              Int              @id @default(autoincrement())
  estudianteId    Int              @map("estudiante_id")
  horarioId       Int              @map("horario_id")
  fecha           DateTime         @db.Date
  horaRegistro    DateTime         @default(now()) @map("hora_registro") @db.Time(0)
  estado          EstadoAsistencia
  observacion     String?          @db.Text
  registradoPorId Int              @map("registrado_por_id")
  justificacionId Int?             @map("justificacion_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  estudiante    Estudiante     @relation(fields: [estudianteId], references: [id])
  horario       Horario        @relation(fields: [horarioId], references: [id])
  registradoPor Usuario        @relation("AsistenciaRegistradaPor", fields: [registradoPorId], references: [id])
  justificacion Justificacion? @relation(fields: [justificacionId], references: [id])

  @@unique([estudianteId, horarioId, fecha])
  @@index([fecha])
  @@index([estudianteId])
  @@index([horarioId, fecha])
  @@map("asistencias")
}

model Justificacion {
  id            Int                 @id @default(autoincrement())
  estudianteId  Int                 @map("estudiante_id")
  fechaInicio   DateTime            @map("fecha_inicio") @db.Date
  fechaFin      DateTime            @map("fecha_fin") @db.Date
  motivo        String              @db.Text
  archivoUrl    String?             @map("archivo_url") @db.Text
  estado        EstadoJustificacion @default(PENDIENTE)
  revisadoPorId Int?                @map("revisado_por_id")
  comentario    String?             @db.Text
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  estudiante  Estudiante   @relation(fields: [estudianteId], references: [id])
  revisadoPor Usuario?     @relation("JustificacionRevisadaPor", fields: [revisadoPorId], references: [id])
  asistencias Asistencia[]

  @@index([estudianteId, estado])
  @@map("justificaciones")
}

// ==========================================
// SISTEMA: NOTIFICACIONES, SESIONES, AUDITORÍA
// ==========================================

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  tipo      String   @db.VarChar(50)
  titulo    String   @db.VarChar(200)
  mensaje   String   @db.Text
  leida     Boolean  @default(false)
  url       String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida])
  @@map("notificaciones")
}

model Sesion {
  id         Int      @id @default(autoincrement())
  usuarioId  Int      @map("usuario_id")
  tokenHash  String   @map("token_hash") @db.Text
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  expiracion DateTime
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesiones")
}

model Auditoria {
  id        Int      @id @default(autoincrement())
  usuarioId Int?     @map("usuario_id")
  accion    String   @db.VarChar(100)
  entidad   String   @db.VarChar(100)
  entidadId Int?     @map("entidad_id")
  detalle   Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidad, entidadId])
  @@map("auditorias")
}

model Configuracion {
  id          Int      @id @default(autoincrement())
  clave       String   @unique @db.VarChar(100)
  valor       String   @db.Text
  tipo        String   @default("texto") @db.VarChar(20)
  descripcion String?  @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("configuraciones")
}
